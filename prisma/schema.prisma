// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ============================================
// DATABASE PROVIDER CONFIGURATION
// ============================================
// For Supabase (PostgreSQL), change:
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
//
// For Local Development (SQLite), change:
//   provider = "sqlite"
//   url      = env("DATABASE_URL")
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CHURCH REPORT MODELS
// ============================================

model ChurchReport {
  id          String   @id @default(cuid())
  churchName  String
  region      String
  month       String
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  osanTama    OsanTama[]
  gastu       Gastu[]
}

model OsanTama {
  id          String   @id @default(cuid())
  deskrisaun  String
  montante    Float
  reportId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation
  report      ChurchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Gastu {
  id            String   @id @default(cuid())
  gastuBaSaida  String
  montante      Float
  reportId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relation
  report        ChurchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  page      String   // 'landing', 'regional', 'nasional'
  author    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// SETTINGS MODEL (for future use)
// ============================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
