// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ============================================
// DATABASE PROVIDER CONFIGURATION
// ============================================
// For Supabase (PostgreSQL):
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
//
// For Local Development (SQLite):
//   provider = "sqlite"
//   url      = env("DATABASE_URL")
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH MODELS
// ============================================

/// Application user — can be SUPER_ADMIN, ADMIN_REGIONAL, or ADMIN_LOKAL
model User {
  id         String   @id @default(cuid())
  /// Email only set for SUPER_ADMIN (Google OAuth). Null for QR-based admins.
  email      String?  @unique
  name       String
  /// 'SUPER_ADMIN' | 'ADMIN_REGIONAL' | 'ADMIN_LOKAL'
  role       String   @default("ADMIN_LOKAL")
  /// Region for ADMIN_REGIONAL (e.g. "Baucau")
  region     String?
  /// Church name for ADMIN_LOKAL
  churchName String?
  /// 'ACTIVE' | 'INACTIVE'
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  qrCodes      QrCode[]
  loginHistory LoginHistory[]
}

/// QR Code token for passwordless login (ADMIN_REGIONAL & ADMIN_LOKAL)
model QrCode {
  id         String    @id @default(cuid())
  /// Unique secure token encoded in the QR code
  token      String    @unique
  userId     String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  /// Optional expiry date — null means no expiry
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Tracks every login event for audit purposes
model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  /// 'GOOGLE' | 'QR_CODE'
  method     String
  /// User-Agent / device info
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// CHURCH REPORT MODELS
// ============================================

model ChurchReport {
  id          String   @id @default(cuid())
  churchName  String
  region      String
  month       String
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  osanTama OsanTama[]
  gastu    Gastu[]
}

model OsanTama {
  id         String   @id @default(cuid())
  deskrisaun String
  montante   Float
  reportId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  report ChurchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Gastu {
  id           String   @id @default(cuid())
  gastuBaSaida String
  montante     Float
  reportId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  report ChurchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  page      String
  author    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
