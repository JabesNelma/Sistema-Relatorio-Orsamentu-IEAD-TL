// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ============================================
// DATABASE PROVIDER CONFIGURATION
// ============================================
// For Supabase (PostgreSQL):
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
//
// For Local Development (SQLite):
//   provider = "sqlite"
//   url      = env("DATABASE_URL")
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH MODELS
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN_REGIONAL
  ADMIN_LOKAL
}

enum QrStatus {
  ACTIVE
  DISABLED
  EXPIRED
  USED
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique // Only for SUPER_ADMIN (Google OAuth)
  name          String
  role          Role       @default(ADMIN_LOKAL)
  region        String?    // For ADMIN_REGIONAL
  churchName    String?    // For ADMIN_LOKAL
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  qrCodes       QrCode[]
  generatedQrCodes QrCode[] @relation("GeneratedQrCodes")
  loginHistory  LoginHistory[]
}

model QrCode {
  id            String     @id @default(cuid())
  token         String     @unique // Secure random token encoded in QR
  userId        String
  status        QrStatus   @default(ACTIVE)
  generatedBy   String     // User ID of SUPER_ADMIN who generated it
  expiresAt     DateTime?  // Optional expiry
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  usedAt        DateTime?  // When the QR was last scanned for login

  // Relations
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generator     User       @relation("GeneratedQrCodes", fields: [generatedBy], references: [id])

  @@index([userId])
  @@index([token])
}

model LoginHistory {
  id            String     @id @default(cuid())
  userId        String
  loginMethod   String     // 'google_oauth' | 'qr_code'
  deviceInfo    String?    // User-Agent string
  ipAddress     String?
  success       Boolean    @default(true)
  createdAt     DateTime   @default(now())

  // Relations
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ============================================
// CHURCH REPORT MODELS (Existing)
// ============================================

model ChurchReport {
  id          String   @id @default(cuid())
  churchName  String
  region      String
  month       String
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  osanTama    OsanTama[]
  gastu       Gastu[]
}

model OsanTama {
  id          String   @id @default(cuid())
  deskrisaun  String
  montante    Float
  reportId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  report      ChurchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Gastu {
  id            String   @id @default(cuid())
  gastuBaSaida  String
  montante      Float
  reportId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  report        ChurchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  page      String
  author    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
