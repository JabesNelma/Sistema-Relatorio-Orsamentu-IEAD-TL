// Prisma schema for Timor-Leste Financial Management System
// Roles: SUPER_ADMIN (Google SSO), ADMIN_REGIONAL & ADMIN_LOKAL (QR code login)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Profile = application user (mirrors Supabase auth.users concept).
// For Super Admin we store an email (Google SSO). For Regional/Lokal admins
// we rely on QR tokens instead of passwords.
model Profile {
  id        String   @id @default(cuid())
  email     String?  @unique // only set for SUPER_ADMIN (Google SSO)
  name      String
  role      String   @default("ADMIN_LOKAL") // SUPER_ADMIN | ADMIN_REGIONAL | ADMIN_LOKAL
  regionId  Int?
  region    Region?  @relation(fields: [regionId], references: [id])
  sukuId    Int?
  suku      Suku?    @relation(fields: [sukuId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tokens   QrToken[]
  reports  FinancialReport[]
  sessions Session[]
}

model Region {
  id             Int            @id @default(autoincrement())
  name           String         @unique // "Regiaun 1"
  code           String         @unique // "R1"
  description    String?
  municipalities Municipality[]
  sukus          Suku[]
  profiles       Profile[]
  createdAt      DateTime       @default(now())

  @@map("regions")
}

model Municipality {
  id        Int      @id @default(autoincrement())
  name      String // "Lautém"
  regionId  Int
  region    Region   @relation(fields: [regionId], references: [id])
  sukus     Suku[]
  createdAt DateTime @default(now())

  @@map("municipalities")
}

model Suku {
  id             Int               @id @default(autoincrement())
  name           String // "Suku Uma Ua"
  municipalityId Int
  municipality   Municipality      @relation(fields: [municipalityId], references: [id])
  regionId       Int
  region         Region            @relation(fields: [regionId], references: [id])
  profiles       Profile[]
  reports        FinancialReport[]
  createdAt      DateTime          @default(now())

  @@map("sukus")
}

// QR login tokens generated by Super Admin. Each token maps to one profile.
// Super Admin can deactivate a token at any time for security.
model QrToken {
  id         String    @id @default(cuid())
  token      String    @unique // random secret embedded in QR code
  profileId  String
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label      String    @default("QR Login") // friendly name
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?

  @@index([profileId])
  @@map("qr_tokens")
}

// Daily financial report entered by Admin Lokal.
// persembahan = offerings, perpuluhan = tithes, kontribusi = other contributions
model FinancialReport {
  id           Int      @id @default(autoincrement())
  date         DateTime
  persembahan  Float    @default(0) // offerings
  perpuluhan   Float    @default(0) // tithes
  kontribusi   Float    @default(0) // other contributions
  catatan      String?  // notes
  sukuId       Int
  suku         Suku     @relation(fields: [sukuId], references: [id])
  createdById  String
  createdBy    Profile  @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sukuId])
  @@index([date])
  @@map("financial_reports")
}

// Simple server-side sessions (cookie token -> profile).
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([profileId])
  @@map("sessions")
}
