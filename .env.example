# Database Configuration (Supabase PostgreSQL)
# Get these from your Supabase project settings
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Super Admin Configuration
# Super Admin login is GOOGLE ONLY. Only this Google account may log in as
# Super Admin. No username/password form is used; verification (Google Prompt /
# phone approval / 2FA) is handled by the user's Google account, not the app.
SUPER_ADMIN_EMAIL=jabesnelma056@gmail.com
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=jabesnelma056@gmail.com

# Base URL for OAuth callbacks
# Update this for production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# JWT Secret for session tokens (minimum 32 characters)
# Generate a secure random string for production
JWT_SECRET=your-secret-key-min-32-characters-long